# ══════════════════════════════════════════════════════════════════════════════
# fnb development environment — copy to .env and boot: cp .env.example .env
#
# EVERY value is REQUIRED unless explicitly marked optional. There are no
# defaults in code or docker-compose.yml — a missing value fails fast at
# `docker compose up` (via ${VAR:?}) or at process start (requiredEnv throw).
#
# NOT here by design (structural constants coupled to docker/Caddyfile, which
# cannot read .env): per-app NUXT_APP_BASE_URL (/auth /tenant /msg /graphql-api
# /storage), NUXT_HOST=0.0.0.0, NUXT_PORT=3000, and the in-container port 3000.
# Change those in docker-compose.yml + docker/Caddyfile in lockstep.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Stack entry point ────────────────────────────────────────────────────────
# Host port Caddy listens on. Every http://localhost:4000/... URL below embeds
# it — if you change PORT, update all of them (deliberate: no derived values).
PORT=4000
# Passed to every app container. Drives cookie `secure` flag (auth-cookies.ts),
# PostGraphile watch/explain/GraphiQL (graphile.config.ts).
NODE_ENV=development
# Vite HMR websocket port as seen from the browser — keep equal to PORT.
VITE_HMR_CLIENT_PORT=4000

# ─── Postgres (db service + migrations) ───────────────────────────────────────
# Dev-only credentials; the db container initializes with these on first boot.
POSTGRES_DB=fnb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
# Host-side port mapping for the db container (container port is always 5432).
DB_HOST_PORT=5444
# Connection string used by all app services (container network, hence
# function_bucket:5432 not localhost:5444). NOTE: superuser today — the role
# downgrade is tracked separately in superuser-database-url.plan.md.
DATABASE_URL=postgresql://postgres:1234@function_bucket:5432/fnb
# Same target, consumed by db-migrate + scripts/db-*.ts:
# PG_URL for psql, DB_URL in sqitch's db:pg: scheme.
PG_URL=postgresql://postgres:1234@function_bucket:5432/fnb
DB_URL=db:pg://postgres:1234@function_bucket:5432/fnb
# Ordered sqitch deploy list. Order matters: fnb-n8n must precede
# fnb-storage / fnb-location-datasets / fnb-airports (n8n_worker grants for the
# asset-scan + sync workflows); all packages must deploy or PostGraphile fails at
# boot (graphile.config.ts exposes their schemas).
DEPLOY_PACKAGES=fnb-auth fnb-app fnb-n8n fnb-res fnb-msg fnb-todo fnb-loc fnb-storage fnb-location-datasets fnb-airports fnb-game

# ─── Public URLs (browser-reachable, through Caddy on PORT) ───────────────────
NUXT_PUBLIC_AUTH_APP_URL=http://localhost:4000/auth
NUXT_PUBLIC_GRAPHQL_API_URL=http://localhost:4000/graphql-api/api/graphql
NUXT_PUBLIC_MSG_APP_URL=http://localhost:4000/msg
NUXT_PUBLIC_UPLOAD_URL=http://localhost:4000/storage/api/upload
# Host-side GraphQL codegen (pnpm graphql-api-generate) — stack must be running.
GRAPHQL_SCHEMA_URL=http://localhost:4000/graphql-api/api/graphql

# ─── Internal URLs (container network, server-to-server) ──────────────────────
NUXT_AUTH_APP_INTERNAL_URL=http://auth-app:3000/auth
NUXT_MSG_APP_INTERNAL_URL=http://msg-app:3000/msg

# ─── MinIO / S3 (asset storage) ───────────────────────────────────────────────
# Root credentials; compose aliases these into S3_ACCESS_KEY / S3_SECRET_KEY so
# there is exactly one credential source.
MINIO_ROOT_USER=fnbminio
MINIO_ROOT_PASSWORD=fnbminio123
# Host port mappings (S3 API / web console at http://localhost:9001).
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# S3 client config. Endpoint is container-net; S3_PUBLIC_BASE_URL is the
# BROWSER-reachable base for public/ objects and presigning — it embeds
# MINIO_API_PORT and S3_BUCKET, keep the three aligned. (CDN URL in prod.)
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_BASE_URL=http://localhost:9000/fnb-assets
S3_REGION=us-east-1              # arbitrary for MinIO; the SDK requires a value
S3_BUCKET=fnb-assets
S3_FORCE_PATH_STYLE=true         # required for MinIO
# ─── ClamAV (malware scanning — worker-app scan-asset handler only) ───────────
CLAMAV_HOST=clamav
CLAMAV_PORT=3310                 # clamd port inside the network
CLAMAV_HOST_PORT=3310            # host mapping (dev debugging only)

# ─── Asset-scan pipeline tunables (n8n asset-scan + reaper workflows) ─────────
# Max scan workflows per asset before the verdict goes terminal 'error'.
ASSET_SCAN_MAX_WF_ATTEMPTS=3
# Pending asset older than this (minutes) with no live workflow gets reaped.
# (The reaper cadence is baked into the asset-scan-reaper workflow's Schedule Trigger.)
ASSET_SCAN_STUCK_MINUTES=15

# ─── Anthropic API (n8n anthropic-api-key credential) ────────────────────────
# Backs the n8n `anthropic-api-key` credential (game-event AI + any x-api-key HTTP node).
# Supply your own; never committed.
ANTHROPIC_API_KEY=

# ─── n8n workflow engine ─────────────────────────────────────────────────────
# Spec: .claude/specs/n8n-parallel-engine/. n8n runs ALONGSIDE agent-app (dual
# engines): per-workflow engine assignment lives in the triggerWorkflow plugin's
# registry. State in the separate n8n_engine DB inside the postgis container.
# Host port for the n8n editor + webhooks (own port, ZITADEL precedent — no Caddy).
N8N_HOST_PORT=5678
# Password for the n8n_engine login role (owner of the n8n_engine database;
# created idempotently by docker/n8n/db-init.sh).
N8N_ENGINE_DB_PASSWORD=change-me-generate-a-random-value
# n8n credential-store encryption key — keep STABLE across rebuilds or imported
# credentials become undecryptable.
N8N_ENCRYPTION_KEY=change-me-generate-a-random-value
# Password for the n8n_worker PG login role in function_bucket (created by the
# fnb-n8n sqitch package; used by n8n's Postgres credential).
N8N_WORKER_PG_PASSWORD=change-me-generate-a-random-value
# Shared webhook-header secret (X-Fnb-Webhook-Secret) — n8n's Header Auth
# credential validates it; graphql-api-app (triggerWorkflow n8n branch) sends it.
N8N_WEBHOOK_SECRET=change-me-generate-a-long-random-value
# Compose-internal base URL for webhook POSTs.
N8N_INTERNAL_URL=http://n8n:5678
# Browser-reachable editor URL — the site-admin n8n Workflows page links out here.
NUXT_PUBLIC_N8N_EDITOR_URL=http://localhost:5678

# ─── Session sealing (issue 0010) ─────────────────────────────────────────────
# Seals (encrypts+authenticates) the httpOnly `session` cookie via h3 useSession.
# AT LEAST 32 characters; every app that parses the session cookie gets it via
# compose. Rotating it invalidates all existing sessions (users just re-login).
NUXT_SESSION_SECRET=dev-session-secret-must-be-32-chars-min
# ─── ZITADEL (identity provider — OIDC login ceremony only) ──────────────────
# Spec: .claude/specs/future-auth/zitadel-login-pattern.md. Own host port like
# minio (the issuer must own its origin — no Caddy path prefix possible).
# Issuer + console: http://localhost:8200
ZITADEL_HOST_PORT=8200
# EXACTLY 32 characters; IMMUTABLE once an instance is initialized. Safe to keep
# a fixed dev value: a rebuild wipes volumes and re-inits with whatever is here.
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
# Runtime login role for the dedicated `zitadel` database (created inside the
# postgis container by docker/db-init/10-create-zitadel-db.sh on a fresh volume).
ZITADEL_DB_PASSWORD=zitadel1234
# Console human admin seeded by FirstInstance (sign in at http://localhost:8200
# as `zitadel-admin`, or `zitadel-admin@fnb.localhost` if prompted for a full
# login name). Complexity policy is relaxed in dev — see docker-compose.yml.
ZITADEL_ADMIN_PASSWORD=poiuytre
# External issuer URL — browser authorize redirects AND id_token `iss` validation
# (auth-app server-side, stage 3). Embeds ZITADEL_HOST_PORT — keep aligned.
NUXT_ZITADEL_ISSUER=http://localhost:8200
# Container-reachable ZITADEL origin — auth-app rewrites token/JWKS/userinfo calls
# to it while presenting the external Host (Decisions (a) in the spec).
NUXT_ZITADEL_INTERNAL_URL=http://zitadel:8080
# { issuer, clientId } handoff written by the zitadel-seed job onto the shared
# zitadel-seed volume; read by auth-app at runtime (stage 3).
NUXT_ZITADEL_SEED_FILE=/zitadel-seed/fnb-web-app.json
# First-run setup (.claude/specs/first-run-setup/): mandatory secret gating POST
# /auth/api/setup/initialize in EVERY environment. Generate with: openssl rand -hex 24
# The operator enters this exact value in the /auth/setup form's "Setup token" field.
SETUP_TOKEN=change-me-openssl-rand-hex-24

# ─── Ops / dev conveniences ───────────────────────────────────────────────────
# Keep-warm pinger interval (seconds).
PING_INTERVAL=30
# Dozzle log viewer: host port + container-name filter.
DOZZLE_PORT=8888
DOZZLE_FILTER=name=fnb

# ─── Third-party ──────────────────────────────────────────────────────────────
# Public (pk.) Mapbox token used by tenant-app's map views. Read at nuxt config
# time — dev-server restart required after changing it.
YOUR TOKEN

# ─── Optional (unset = feature-specific, not needed to boot) ──────────────────
# Alpha Vantage API key for the wf-exerciser stock-quote step (currently stubbed).
# ALPHA_VANTAGE_KEY=
# Cookie domain override for the session cookie (empty/unset = host-only).
# NUXT_COOKIE_DOMAIN=
# Sentry DSN (project `fnb`). Public value (shipped to the browser) — empty/unset
# disables the SDK, so the stack boots fine without it. Consumed by home-app:
# NUXT_PUBLIC_SENTRY_DSN (client) + SENTRY_DSN (server) both read this one var.
# SENTRY_DSN=https://<key>@o<org>.ingest.us.sentry.io/<project>

{
  version: 1,
  config: {
    /*
     * There can be entries here for:
     *
     * - `class`: for tables, composite types, views and materialized views
     * - `attribute`: for columns/attributes (of any 'class' type)
     * - `constraint`: for table constraints
     * - `procedure`: for functions/procedures
     */
    procedure: {
      /*
       * n8n run-log read fn: kept renamed to n8nWorkflowRunsList (from when an agent run-log
       * read fn coexisted). (agentic-decommission spec)
       */
      'n8n_api.workflow_runs': {
        tags: { name: 'n8n_workflow_runs' },
      },

      /*
       * notify send log read fn (gated p:app-admin-super). Renamed to notifyNotificationsList so
       * the function field cannot collide with the notify.notification table's auto-generated list
       * field (same shape as the n8n_workflow_runs rename). (notifications spec, _shared.data.md)
       */
      'notify_api.notifications': {
        tags: { name: 'notify_notifications' },
      },
    },

    constraint: {
      /*
       * Self-referential tenant FK (workspace tenants). Explicit names preempt the
       * simplify-inflection attempts that logged recoverable "naming conflict" warnings
       * ('tenant') at schema build. (admin/workspace spec, _shared.data.md)
       */
      tenant_parent_tenant_id_fkey: {
        tags: {
          fieldName: 'parentTenant',
          foreignFieldName: 'childTenants',
          foreignSimpleFieldName: 'childTenantsList',
        },
      },
    },

    class: {
      /*
       * Hide the internal object-location columns from the exposed schema. They stay in the DB
       * (the downloadUrl presign plan still reads them server-side), but clients get metadata +
       * the computed downloadUrl only — never the raw storage_key / bucket. (asset-storage spec,
       * graphql.data.md §2)
       */
      asset: {
        attribute: {
          storage_key: { tags: { behavior: '-select -filterBy -orderBy' } },
          bucket: { tags: { behavior: '-select -filterBy -orderBy' } },
        },
      },

      /*
       * n8n run log: reads go through the gated n8n_api.workflow_runs function
       * (p:app-admin-super). Drop the table's own all-rows root fields (no client purpose;
       * they'd collide with the function's list field). The `n8n_workflow_run` rename +
       * the enum's smart COMMENT rename in the deploy SQL are retained from when a second
       * (agent) run-log schema coexisted; renaming back now would only churn codegen.
       * (agentic-decommission spec, _shared.data.md)
       */
      'n8n.workflow_run': {
        tags: {
          name: 'n8n_workflow_run',
          behavior: '-query:resource:list -query:resource:connection',
        },
      },

      /*
       * notify send log: reads go through the gated notify_api.notifications function
       * (p:app-admin-super). Drop the table's own all-rows root fields (no client purpose; they'd
       * collide with the function's list field) — same posture as n8n.workflow_run. Single lookups
       * + FK relations stay. (notifications spec, _shared.data.md)
       */
      'notify.notification': {
        tags: {
          behavior: '-query:resource:list -query:resource:connection',
        },
      },

      /*
       * notify.phone_verification holds bcrypt-hashed OTP codes — never in the graph. All access is
       * via notify_fn (SECURITY DEFINER); RLS is deny-all to clients too. (notifications spec,
       * _shared.data.md → SMS additions / D13)
       */
      'notify.phone_verification': {
        tags: { behavior: '-*' },
      },

      /*
       * notify.channel_preference is user-owned: reads go through the auto-generated list
       * (RLS-scoped to jwt.profile_id() via channel_pref_self); writes only through
       * notify_api.set_channel_preference / verify_phone_code (SECURITY INVOKER → notify_fn).
       * Default mutations are already disabled globally (makeV4Preset disableDefaultMutations).
       */

      /*
       * Game server (game-server spec, _shared.data.md §PostGraphile exposure):
       * - game_event_state holds authoritative state + per-seat snapshots (ship
       *   positions!) — never in the graph; reads only via game_api.game_view.
       * - game/game_event: list reads go through game_api.my_games / the Game relations;
       *   root all-rows fields dropped, single lookups + FK relations stay.
       * - game_type keeps its root list (gameTypeList) — reference data for the UI.
       */
      'game.game_event_state': {
        tags: { behavior: '-*' },
      },
      'game.game': {
        tags: { behavior: '-query:resource:list -query:resource:connection' },
      },
      'game.game_event': {
        tags: { behavior: '-query:resource:list -query:resource:connection' },
      },
      'game.game_player': {
        tags: { behavior: '-query:resource:list -query:resource:connection' },
      },

      /*
       * URN registry: res.module_permission is pure RLS plumbing — never served.
       * (urn-registry spec, client.data.md §1. Hub-relation renames, e.g.
       * assetsBySubjectUrn → assets on Resource, land after first codegen once the
       * inflected names are known.)
       */
      'res.module_permission': {
        tags: { behavior: '-*' },
      },

      /*
       * Override the description sourced from the PostgreSQL COMMENT on the
       * `permission` table (surfaced in the license-permission admin UI).
       */
      permission: {
        description: "A permission that a license can allow.",
      },
    },
  },
}
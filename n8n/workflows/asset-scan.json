      "name": "Parse Verdict",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1540,
        560
      ],
      "parameters": {
        "jsCode": "const out = $json.stdout || ''\nconst m = out.match(/CLAMEXIT:(\\d+)/)\nconst code = m ? parseInt(m[1], 10) : 2\nconst asset = $('Get Asset').first().json.asset\nconst finalKey = asset.storage_key.replace(/^quarantine\\//, asset.is_public ? 'public/' : 'private/')\nlet verdict = 'error'\nlet signature = null\nif (code === 0) verdict = 'clean'\nelse if (code === 1) { verdict = 'infected'; const s = out.match(/:\\s*(.+?)\\s+FOUND/); signature = s ? s[1] : 'unknown' }\nreturn [{ json: { verdict, signature, finalKey, clamExit: code, clamOut: out.trim() } }]"
      },
      "id": "c0000000-0000-4000-8000-000000000009"

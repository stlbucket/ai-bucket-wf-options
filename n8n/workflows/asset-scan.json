      "parameters": {
        "executeOnce": true,
        "command": "=ffmpeg -y -i /home/node/.n8n-files/scan-{{ $('Webhook').item.json.body.assetId }} -vf \"scale=w=256:h=256:force_original_aspect_ratio=decrease\" /home/node/.n8n-files/thumb-{{ $('Webhook').item.json.body.assetId }}.webp >/dev/null 2>&1 && sha256sum /home/node/.n8n-files/thumb-{{ $('Webhook').item.json.body.assetId }}.webp | cut -d' ' -f1 && stat -c%s /home/node/.n8n-files/thumb-{{ $('Webhook').item.json.body.assetId }}.webp"

      "name": "Prep Thumb",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3300,
        340
      ],
      "parameters": {
        "jsCode": "const out = ($json.stdout || '').trim()\nconst lines = out.split('\\n').map(s => s.trim()).filter(Boolean)\nconst checksum = lines[0] && /^[0-9a-f]{64}$/.test(lines[0]) ? lines[0] : null\nconst size = checksum && lines[1] ? parseInt(lines[1], 10) : null\nif (!checksum || !size) return [{ json: { skip: true } }]\nconst finalKey = $('Parse Verdict').first().json.finalKey\nconst dir = finalKey.slice(0, finalKey.lastIndexOf('/'))\nconst thumbId = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => { const r = Math.random() * 16 | 0; return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16) })\nreturn [{ json: { skip: false, thumbId, childKey: `${dir}/${thumbId}.webp`, checksum, size } }]"
      },
      "id": "c0000000-0000-4000-8000-000000000022"

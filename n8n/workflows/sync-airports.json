        440
      ],
      "parameters": {
        "jsCode": "const files = {}\nfor (const i of $input.all()) {\n  const j = i.json\n  if (j.skipped) files[j.file] = { skipped: true }\n  else if (j.failed) files[j.file] = { failed: j.failed }\n  else files[j.file] = { rowCount: j.rowCount, inserted: j.inserted, updated: j.updated, skippedRows: j.skippedRows }\n}\nreturn [{ json: { files } }]"
      },

        "jsCode": "const results = $input.all().map((i) => i.json.result)\nconst inserted = results.reduce((s, r) => s + (r?.inserted ?? 0), 0)\nconst updated = results.reduce((s, r) => s + (r?.updated ?? 0), 0)\nconst skippedRows = results.reduce((s, r) => s + (r?.skipped ?? 0), 0)\nreturn [{ json: { file: $('Loop Files').first().json.file, rowCount: $('Map And Chunk').first().json.rowCount, inserted, updated, skippedRows } }]"

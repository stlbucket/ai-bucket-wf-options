    {
      "name": "Map And Chunk",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2660,
        900
      ],
      "parameters": {
        "jsCode": "const file = $('Loop Files').first().json.file\nconst clean = (obj) => { const out = {}; for (const k of Object.keys(obj)) out[k.replace(/^\\uFEFF/, '')] = obj[k]; return out }\nconst s = (v) => { const t = v == null ? '' : String(v).trim(); return t ? t : null }\nconst int = (v) => { const t = v == null ? '' : String(v).trim(); if (!t) return null; const n = Number.parseInt(t, 10); return Number.isNaN(n) ? null : n }\nconst num = (v) => { const t = v == null ? '' : String(v).trim(); if (!t) return null; const n = Number.parseFloat(t); return Number.isNaN(n) ? null : n }\n// same coercion maps as apps/agent-app/server/lib/agent-tools/airports.ts (incl. the\n// le/he_heading_degT and usageType header quirks)\nconst MAPS = {\n  'countries.csv': (r) => ({ id: int(r.id), code: s(r.code), name: s(r.name), continent: s(r.continent), wikipedia_link: s(r.wikipedia_link), keywords: s(r.keywords) }),\n  'regions.csv': (r) => ({ id: int(r.id), code: s(r.code), local_code: s(r.local_code), name: s(r.name), continent: s(r.continent), iso_country: s(r.iso_country), wikipedia_link: s(r.wikipedia_link), keywords: s(r.keywords) }),\n  'airports.csv': (r) => ({ id: int(r.id), ident: s(r.ident), type: s(r.type), name: s(r.name), latitude_deg: s(r.latitude_deg), longitude_deg: s(r.longitude_deg), elevation_ft: int(r.elevation_ft), continent: s(r.continent), iso_country: s(r.iso_country), iso_region: s(r.iso_region), municipality: s(r.municipality), scheduled_service: String(r.scheduled_service ?? '').trim().toLowerCase() === 'yes', icao_code: s(r.icao_code), iata_code: s(r.iata_code), gps_code: s(r.gps_code), local_code: s(r.local_code), home_link: s(r.home_link), wikipedia_link: s(r.wikipedia_link), keywords: s(r.keywords) }),\n  'runways.csv': (r) => ({ id: int(r.id), airport_ref: int(r.airport_ref), length_ft: int(r.length_ft), width_ft: int(r.width_ft), surface: s(r.surface), lighted: String(r.lighted ?? '').trim() === '1', closed: String(r.closed ?? '').trim() === '1', le_ident: s(r.le_ident), le_latitude_deg: s(r.le_latitude_deg), le_longitude_deg: s(r.le_longitude_deg), le_elevation_ft: int(r.le_elevation_ft), le_heading_deg_t: num(r.le_heading_degT), le_displaced_threshold_ft: int(r.le_displaced_threshold_ft), he_ident: s(r.he_ident), he_latitude_deg: s(r.he_latitude_deg), he_longitude_deg: s(r.he_longitude_deg), he_elevation_ft: int(r.he_elevation_ft), he_heading_deg_t: num(r.he_heading_degT), he_displaced_threshold_ft: int(r.he_displaced_threshold_ft) }),\n  'airport-frequencies.csv': (r) => ({ id: int(r.id), airport_ref: int(r.airport_ref), type: s(r.type), description: s(r.description), frequency_mhz: num(r.frequency_mhz) }),\n  'navaids.csv': (r) => ({ id: int(r.id), ident: s(r.ident), name: s(r.name), type: s(r.type), frequency_khz: num(r.frequency_khz), latitude_deg: s(r.latitude_deg), longitude_deg: s(r.longitude_deg), elevation_ft: int(r.elevation_ft), iso_country: s(r.iso_country), dme_frequency_khz: num(r.dme_frequency_khz), dme_channel: s(r.dme_channel), dme_latitude_deg: s(r.dme_latitude_deg), dme_longitude_deg: s(r.dme_longitude_deg), dme_elevation_ft: int(r.dme_elevation_ft), slaved_variation_deg: num(r.slaved_variation_deg), magnetic_variation_deg: num(r.magnetic_variation_deg), usage_type: s(r.usageType), power: s(r.power), associated_airport: s(r.associated_airport) })\n}\nconst map = MAPS[file]\nconst rows = $input.all().map((i) => map(clean(i.json)))\nconst chunks = []\nfor (let o = 0; o < rows.length; o += 1000) chunks.push(rows.slice(o, o + 1000))\nreturn chunks.map((chunk) => ({ json: { file, chunk, rowCount: rows.length } }))"
      },
      "id": "0aaaf27a-8acd-4117-82f9-26c5407c069a"
